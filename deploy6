        const surahsData = surahNames.map((name, index) => ({ id: index + 1, name: name }));

        function getActiveMoshaf(reciter) {
            const idx = state.moshafIndex[reciter.id] || 0;
            return reciter.moshaf[idx] || reciter.moshaf[0];
        }

        let state = {
            currentTab: 'reciters',
            reciter: recitersData[0],
            surahId: 1,
            isPlaying: false,
            favorites: JSON.parse(localStorage.getItem('quran_favs')) || [],
            theme: localStorage.getItem('theme') || 'light',
            currentPage: 1,
            itemsPerPage: 20,
            playbackMode: 'list',
            savedTracks: JSON.parse(localStorage.getItem('quran_saved_tracks')) || [],
            moshafIndex: JSON.parse(localStorage.getItem('quran_moshaf_index')) || {}
        };

        const audio = document.getElementById('audioPlayer');
        const playBtn = document.getElementById('playBtn');
        const progressBar = document.getElementById('progressBar');
        const searchInput = document.getElementById('searchInput');
        const recitersGrid = document.getElementById('recitersGrid');
        const surahsList = document.getElementById('surahsList');
        const modeBtn = document.getElementById('modeBtn');
        const randomBtn = document.getElementById('randomBtn');

        function init() {
            setTheme(state.theme);
            renderView();
            setupEventListeners();
        }

        function renderView() {
            const term = searchInput.value.toLowerCase();
            let list = [];

            if (state.currentTab === 'reciters') {
                list = recitersData.filter(r => r.name.includes(term));
                document.getElementById('pagination').style.display = 'flex';
                renderPaginatedReciters(list);
            } else if (state.currentTab === 'surahs') {
                const moshaf = getActiveMoshaf(state.reciter);
                list = surahsData.filter(s => s.name.includes(term));
                document.getElementById('pagination').style.display = 'none';
                renderSurahs(list);
            } else if (state.currentTab === 'favorites') {
                list = recitersData.filter(r => state.favorites.includes(r.id) && r.name.includes(term));
                document.getElementById('pagination').style.display = 'none';
                renderReciters(list);
            } else if (state.currentTab === 'saved_tracks') {
                list = state.savedTracks.filter(t => {
                    const rName = recitersData.find(r => r.id === t.reciterId)?.name || '';
                    const sName = surahsData.find(s => s.id === t.surahId)?.name || '';
                    return rName.includes(term) || sName.includes(term);
                });
                document.getElementById('pagination').style.display = 'none';
                renderSavedTracks(list);
            }
        }

        function renderPaginatedReciters(list) {
            const totalPages = Math.ceil(list.length / state.itemsPerPage);
            state.currentPage = Math.min(state.currentPage, totalPages || 1);
            const start = (state.currentPage - 1) * state.itemsPerPage;
            const paginatedList = list.slice(start, start + state.itemsPerPage);
            renderReciters(paginatedList);
            document.getElementById('pageInfo').textContent = `صفحة ${state.currentPage} من ${totalPages || 1}`;
            document.getElementById('prevPage').disabled = state.currentPage === 1;
            document.getElementById('nextPage').disabled = state.currentPage === totalPages || totalPages === 0;
        }

        function renderReciters(list) {
            recitersGrid.innerHTML = list.length ? '' : '<p style="text-align:center; width:100%; color:var(--text-secondary)">لا توجد نتائج</p>';
            list.forEach(r => {
                const card = document.createElement('div');
                card.className = `card ${r.id === state.reciter.id ? 'active' : ''}`;
                card.onclick = (e) => {
                    if (e.target.closest('.fav-btn')) return;
                    handleReciterClick(r);
                };
                const isFav = state.favorites.includes(r.id);
                const moshafBadge = r.moshaf.length > 1
                    ? `<span style="font-size:0.75rem;color:var(--accent);margin-right:4px;">(روايات: ${r.moshaf.length})</span>`
                    : '';
                const activeMoshaf = getActiveMoshaf(r);
                card.innerHTML = `
                    <div class="card-icon"><i class="fas fa-microphone-alt"></i></div>
                    <div class="card-info">
                        <h3 class="card-title">${r.name}${moshafBadge}</h3>
                        <p class="card-meta">${activeMoshaf.name}</p>
                    </div>
                    <button class="fav-btn ${isFav ? 'is-fav' : ''}" onclick="toggleFav(${r.id}, this)">
                        <i class="${isFav ? 'fas' : 'far'} fa-heart"></i>
                    </button>`;
                recitersGrid.appendChild(card);
            });
        }

        function handleReciterClick(reciter) {
            if (reciter.moshaf.length === 1) {
                state.moshafIndex[reciter.id] = 0;
                saveMoshafIndex();
                loadTrack(reciter, state.surahId);
            } else {
                showMoshafPicker(reciter);
            }
        }

        function showMoshafPicker(reciter) {
            const existing = document.getElementById('moshafPickerOverlay');
            if (existing) existing.remove();

            const overlay = document.createElement('div');
            overlay.id = 'moshafPickerOverlay';
            overlay.style.cssText = `
                position:fixed; inset:0; background:rgba(0,0,0,0.5);
                z-index:9999; display:flex; align-items:center; justify-content:center; padding:20px;
            `;

            const box = document.createElement('div');
            box.style.cssText = `
                background:var(--bg-surface); border-radius:var(--radius-lg);
                padding:24px; max-width:480px; width:100%;
                border:1px solid var(--border); box-shadow:var(--shadow-hover);
                max-height:80vh; overflow-y:auto;
            `;

            const currentMoshafIdx = state.moshafIndex[reciter.id] || 0;
            box.innerHTML = `
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                    <h3 style="font-family:var(--font-heading);color:var(--primary);font-size:1.2rem;">
                        اختر رواية — ${reciter.name}
                    </h3>
                    <button id="closeMoshafPicker" style="color:var(--text-secondary);font-size:1.4rem;padding:4px 8px;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div id="moshafPickerList" class="surah-list" style="grid-template-columns:1fr;">
                    ${reciter.moshaf.map((m, idx) => `
                        <div class="surah-item ${idx === currentMoshafIdx ? 'active' : ''}"
                             data-idx="${idx}" style="cursor:pointer;">
                            <div class="surah-info">
                                <div class="surah-number">${idx + 1}</div>
                                <div>
                                    <div style="font-weight:600;">${m.name}</div>
                                    <div style="font-size:0.8rem;color:var(--text-secondary);">عدد السور: ${m.surah_total}</div>
                                </div>
                            </div>
                            <i class="far fa-play-circle"></i>
                        </div>
                    `).join('')}
                </div>`;

            overlay.appendChild(box);
            document.body.appendChild(overlay);

            overlay.onclick = (e) => { if (e.target === overlay) overlay.remove(); };
            document.getElementById('closeMoshafPicker').onclick = () => overlay.remove();

            document.getElementById('moshafPickerList').querySelectorAll('.surah-item').forEach(item => {
                item.onclick = () => {
                    const idx = parseInt(item.dataset.idx);
                    state.moshafIndex[reciter.id] = idx;
                    saveMoshafIndex();
                    overlay.remove();
                    const newMoshaf = reciter.moshaf[idx];
                    const safeSurahId = Math.min(state.surahId, newMoshaf.surah_total);
                    loadTrack(reciter, safeSurahId);
                };
            });
        }

        function saveMoshafIndex() {
            localStorage.setItem('quran_moshaf_index', JSON.stringify(state.moshafIndex));
        }

        function renderSurahs(list) {
            surahsList.innerHTML = '';
            list.forEach(s => {
                const item = document.createElement('div');
                item.className = `surah-item ${s.id === state.surahId ? 'active' : ''}`;
                item.onclick = () => loadTrack(state.reciter, s.id);
                item.innerHTML = `
                    <div class="surah-info">
                        <div class="surah-number">${s.id}</div>
                        <span class="surah-name">سورة ${s.name}</span>
                    </div>
                    <i class="far fa-play-circle"></i>`;
                surahsList.appendChild(item);
            });
        }

        function loadTrack(reciter, surahId) {
            const moshaf = getActiveMoshaf(reciter);
            surahId = Math.max(1, Math.min(surahId, moshaf.surah_total));
            state.reciter = reciter;
            state.surahId = surahId;
            const paddedId = String(surahId).padStart(3, '0');
            const surahName = surahsData.find(s => s.id === surahId).name;
            audio.src = `${moshaf.server}${paddedId}.mp3`;
            audio.onerror = () => {
                const toast = document.createElement('div');
                toast.className = 'error-toast';
                toast.innerText = 'عذراً، هذه السورة غير متوفرة حالياً من المصدر';
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 4000);
                updateSaveTrackBtn();
            };
            document.getElementById('currentSurahName').textContent = `سورة ${surahName}`;
            document.getElementById('currentReciterName').textContent = `${reciter.name} — ${moshaf.name}`;
            updateMediaSession(reciter.name, surahName);
            highlightActive();
            playAudio();
            updateSaveTrackBtn();
            if (window.innerWidth < 768) window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function playAudio() {
            audio.play().then(() => { state.isPlaying = true; updatePlayBtn(); }).catch(() => {});
        }

        function togglePlay() {
            if (!audio.getAttribute('src')) {
                loadTrack(state.reciter, state.surahId);
                return;
            }
            if (state.isPlaying) { audio.pause(); } else { playAudio(); }
            state.isPlaying = !state.isPlaying;
            updatePlayBtn();
        }

        function updatePlayBtn() {
            playBtn.innerHTML = state.isPlaying
                ? '<i class="fas fa-pause"></i>'
                : '<i class="fas fa-play" style="margin-right: -4px;"></i>';
        }

        function highlightActive() {
            document.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.surah-item').forEach(s => s.classList.remove('active'));
            renderView();
        }

        function toggleMode() {
            if (state.playbackMode === 'list') {
                state.playbackMode = 'repeat';
                modeBtn.innerHTML = '<i class="fas fa-redo"></i>';
                modeBtn.classList.add('active-mode');
                modeBtn.title = 'إعادة السورة الحالية';
            } else {
                state.playbackMode = 'list';
                modeBtn.innerHTML = '<i class="fas fa-list-ol"></i>';
                modeBtn.classList.remove('active-mode');
                modeBtn.title = 'تشغيل تتابعي';
            }
        }

        function playRandom() {
            const randomReciter = recitersData[Math.floor(Math.random() * recitersData.length)];
            const randomMoshafIdx = Math.floor(Math.random() * randomReciter.moshaf.length);
            state.moshafIndex[randomReciter.id] = randomMoshafIdx;
            saveMoshafIndex();
            const moshaf = randomReciter.moshaf[randomMoshafIdx];
            const randomSurahId = Math.floor(Math.random() * moshaf.surah_total) + 1;
            loadTrack(randomReciter, randomSurahId);
        }

        function onTrackEnded() {
            if (state.playbackMode === 'repeat') {
                audio.currentTime = 0;
                playAudio();
            } else {
                const moshaf = getActiveMoshaf(state.reciter);
                if (state.surahId < moshaf.surah_total) loadTrack(state.reciter, state.surahId + 1);
            }
        }

        window.toggleFav = function(id, btn) {
            const idx = state.favorites.indexOf(id);
            if (idx === -1) state.favorites.push(id); else state.favorites.splice(idx, 1);
            localStorage.setItem('quran_favs', JSON.stringify(state.favorites));
            renderView();
        };

        function toggleSavedTrack() {
            const index = state.savedTracks.findIndex(
                t => t.reciterId === state.reciter.id && t.surahId === state.surahId
            );
            if (index === -1) {
                state.savedTracks.push({
                    reciterId: state.reciter.id,
                    surahId: state.surahId,
                    moshafIdx: state.moshafIndex[state.reciter.id] || 0
                });
            } else {
                state.savedTracks.splice(index, 1);
            }
            localStorage.setItem('quran_saved_tracks', JSON.stringify(state.savedTracks));
            updateSaveTrackBtn();
            if (state.currentTab === 'saved_tracks') renderView();
        }

        function updateSaveTrackBtn() {
            const btn = document.getElementById('saveTrackBtn');
            const isSaved = state.savedTracks.some(
                t => t.reciterId === state.reciter.id && t.surahId === state.surahId
            );
            if (isSaved) {
                btn.innerHTML = '<i class="fas fa-heart"></i>';
                btn.classList.add('is-saved');
            } else {
                btn.innerHTML = '<i class="far fa-heart"></i>';
                btn.classList.remove('is-saved');
            }
        }

        function downloadTrack() {
            const moshaf = getActiveMoshaf(state.reciter);
            const paddedId = String(state.surahId).padStart(3, '0');
            const url = `${moshaf.server}${paddedId}.mp3`;
            const a = document.createElement('a');
            a.href = url;
            a.target = '_blank';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        function renderSavedTracks(list) {
            const grid = document.getElementById('savedTracksGrid');
            grid.innerHTML = list.length ? '' : '<p style="text-align:center; width:100%; color:var(--text-secondary)">لا توجد تلاوات محفوظة</p>';
            list.forEach(t => {
                const reciter = recitersData.find(r => r.id === t.reciterId);
                const surah = surahsData.find(s => s.id === t.surahId);
                if (!reciter || !surah) return;
                const savedMoshafIdx = t.moshafIdx || 0;
                const moshaf = reciter.moshaf[savedMoshafIdx] || reciter.moshaf[0];
                const isActive = t.reciterId === state.reciter.id && t.surahId === state.surahId;
                const card = document.createElement('div');
                card.className = `card ${isActive ? 'active' : ''}`;
                card.onclick = (e) => {
                    if (e.target.closest('.delete-btn')) return;
                    state.moshafIndex[reciter.id] = savedMoshafIdx;
                    saveMoshafIndex();
                    loadTrack(reciter, surah.id);
                };
                card.innerHTML = `
                    <div class="card-icon"><i class="fas fa-play"></i></div>
                    <div class="card-info">
                        <h3 class="card-title">سورة ${surah.name}</h3>
                        <p class="card-meta">${reciter.name} — ${moshaf.name}</p>
                    </div>
                    <button class="fav-btn delete-btn"
                            onclick="removeSavedTrack(${t.reciterId}, ${t.surahId}, event)"
                            title="حذف من تلاواتي">
                        <i class="fas fa-trash-alt"></i>
                    </button>`;
                grid.appendChild(card);
            });
        }

        window.removeSavedTrack = function(reciterId, surahId, event) {
            event.stopPropagation();
            state.savedTracks = state.savedTracks.filter(
                t => !(t.reciterId === reciterId && t.surahId === surahId)
            );
            localStorage.setItem('quran_saved_tracks', JSON.stringify(state.savedTracks));
            updateSaveTrackBtn();
            renderView();
        };

        function setupEventListeners() {
            playBtn.onclick = togglePlay;
            modeBtn.onclick = toggleMode;
            randomBtn.onclick = playRandom;

            document.getElementById('themeBtn').onclick = () =>
                setTheme(state.theme === 'light' ? 'dark' : 'light');

            document.getElementById('nextBtn').onclick = () => {
                if (state.surahId > 1) loadTrack(state.reciter, state.surahId - 1);
            };
            document.getElementById('prevBtn').onclick = () => {
                const moshaf = getActiveMoshaf(state.reciter);
                if (state.surahId < moshaf.surah_total) loadTrack(state.reciter, state.surahId + 1);
            };

            document.getElementById('nextPage').onclick = () => { state.currentPage++; renderView(); };
            document.getElementById('prevPage').onclick = () => { state.currentPage--; renderView(); };
            document.getElementById('saveTrackBtn').onclick = toggleSavedTrack;
            document.getElementById('downloadBtn').onclick = downloadTrack;
            searchInput.oninput = () => { state.currentPage = 1; renderView(); };

            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.onclick = () => {
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    state.currentTab = btn.dataset.tab;
                    state.currentPage = 1;
                    const sInput = document.getElementById('searchInput');
                    sInput.value = '';
                    if (state.currentTab === 'reciters') sInput.placeholder = 'بحث عن قارئ...';
                    else if (state.currentTab === 'surahs') sInput.placeholder = 'بحث عن سورة...';
                    else if (state.currentTab === 'favorites') sInput.placeholder = 'بحث في المفضلة...';
                    else if (state.currentTab === 'saved_tracks') sInput.placeholder = 'بحث عن تلاوة (سورة أو قارئ)...';
                    document.getElementById('recitersSection').style.display =
                        (state.currentTab === 'reciters' || state.currentTab === 'favorites') ? 'block' : 'none';
                    document.getElementById('surahsSection').style.display =
                        state.currentTab === 'surahs' ? 'block' : 'none';
                    document.getElementById('savedTracksSection').style.display =
                        state.currentTab === 'saved_tracks' ? 'block' : 'none';
                    renderView();
                };
            });

            document.addEventListener('keydown', function(event) {
                if (event.target.tagName.toLowerCase() === 'input') return;
                if (event.code === 'Space') {
                    event.preventDefault(); togglePlay();
                } else if (event.code === 'ArrowUp') {
                    event.preventDefault(); audio.volume = Math.min(1, audio.volume + 0.1);
                } else if (event.code === 'ArrowDown') {
                    event.preventDefault(); audio.volume = Math.max(0, audio.volume - 0.1);
                }
            });

            audio.onended = onTrackEnded;
            audio.ontimeupdate = () => {
                if (isNaN(audio.duration)) return;
                const pct = (audio.currentTime / audio.duration) * 100;
                progressBar.value = pct;
                const isDark = state.theme === 'dark';
                const baseColor = isDark ? '#2A3836' : '#E0DCD5';
                const activeColor = '#D4AF37';
                progressBar.style.background =
                    `linear-gradient(to left, ${activeColor} ${pct}%, ${baseColor} ${pct}%)`;
                document.getElementById('currentTime').textContent = formatTime(audio.currentTime);
                document.getElementById('duration').textContent = formatTime(audio.duration);
            };

            progressBar.oninput = (e) => {
                audio.currentTime = (e.target.value / 100) * audio.duration;
            };

            if ('mediaSession' in navigator) {
                navigator.mediaSession.setActionHandler('play', () => playAudio());
                navigator.mediaSession.setActionHandler('pause', () => {
                    audio.pause(); state.isPlaying = false; updatePlayBtn();
                });
                navigator.mediaSession.setActionHandler('previoustrack', () => {
                    if (state.surahId > 1) loadTrack(state.reciter, state.surahId - 1);
                });
                navigator.mediaSession.setActionHandler('nexttrack', () => {
                    const moshaf = getActiveMoshaf(state.reciter);
                    if (state.surahId < moshaf.surah_total) loadTrack(state.reciter, state.surahId + 1);
                });
            }
        }

        function setTheme(t) {
            document.documentElement.setAttribute('data-theme', t);
            state.theme = t;
            localStorage.setItem('theme', t);
            document.getElementById('themeBtn').innerHTML =
                t === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            if (audio.duration) audio.ontimeupdate();
        }

        function formatTime(s) {
            const m = Math.floor(s / 60);
            const sec = Math.floor(s % 60);
            return `${m < 10 ? '0' : ''}${m}:${sec < 10 ? '0' : ''}${sec}`;
        }

        function updateMediaSession(reciterName, surahName) {
            if ('mediaSession' in navigator) {
                navigator.mediaSession.metadata = new MediaMetadata({
                    title: `سورة ${surahName}`,
                    artist: reciterName,
                    album: 'القرآن الكريم',
                    artwork: [
                        { src: 'https://cdn-icons-png.flaticon.com/512/3069/3069172.png', sizes: '512x512', type: 'image/png' }
                    ]
                });
            }
        }

        init();
    </script>
</body>
</html>

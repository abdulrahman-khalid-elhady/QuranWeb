            { id: 40, name: "نبيل الرفاعي", style: "حفص", server: "https://server9.mp3quran.net/nabil/", backup: "https://download.quranicaudio.com/quran/nabil_ar-rifai/" },
            { id: 41, name: "الدوكالي محمد العالم", style: "قالون", server: "https://server7.mp3quran.net/dokali/", backup: "https://download.quranicaudio.com/quran/dukali_muhammad_al-alim/" },
            { id: 42, name: "الزين محمد أحمد", style: "حفص", server: "https://server9.mp3quran.net/alzain/", backup: "" },
            { id: 43, name: "صلاح البدير", style: "حفص", server: "https://server6.mp3quran.net/s_bud/", backup: "https://download.quranicaudio.com/quran/salah_albudair/" },
            { id: 44, name: "عبدالمحسن القاسم", style: "حفص", server: "https://server8.mp3quran.net/qasm/", backup: "https://download.quranicaudio.com/quran/abdul_muhsin_alqasim/" },
            { id: 45, name: "علي جابر", style: "حفص", server: "https://server11.mp3quran.net/a_jbr/", backup: "https://download.quranicaudio.com/quran/ali_jaber/" },
            { id: 46, name: "محمد المحيسني", style: "حفص", server: "https://server11.mp3quran.net/mhsny/", backup: "" },
            { id: 47, name: "هيثم الجدعاني", style: "حفص", server: "https://server16.mp3quran.net/hitham/", backup: "" },
            { id: 48, name: "إبراهيم الأخضر", style: "حفص", server: "https://server6.mp3quran.net/akhdr/", backup: "https://download.quranicaudio.com/quran/ibrahim_al-akhdar/" },
            { id: 49, name: "جمال شاكر عبدالله", style: "حفص", server: "https://server6.mp3quran.net/jamal/", backup: "" },
            { id: 50, name: "شيخ أبو بكر الشاطري", style: "حفص", server: "https://server11.mp3quran.net/shatri/", backup: "" }
        ];

        const surahNames = [
            "الفاتحة", "البقرة", "آل عمران", "النساء", "المائدة", "الأنعام", "الأعراف", "الأنفال", "التوبة", "يونس",
            "هود", "يوسف", "الرعد", "إبراهيم", "الحجر", "النحل", "الإسراء", "الكهف", "مريم", "طه",
            "الأنبياء", "الحج", "المؤمنون", "النور", "الفرقان", "الشعراء", "النمل", "القصص", "العنكبوت", "الروم",
            "لقمان", "السجدة", "الأحزاب", "سبأ", "فاطر", "يس", "الصافات", "ص", "الزمر", "غافر",
            "فصلت", "الشورى", "الزخرف", "الدخان", "الجاثية", "الأحقاف", "محمد", "الفتح", "الحجرات", "ق",
            "الذاريات", "الطور", "النجم", "القمر", "الرحمن", "الواقعة", "الحديد", "المجادلة", "الحشر", "الممتحنة",
            "الصف", "الجمعة", "المنافقون", "التغابن", "الطلاق", "التحريم", "الملك", "القلم", "الحاقة", "المعارج",
            "نوح", "الجن", "المزمل", "المدثر", "القيامة", "الإنسان", "المرسلات", "النبأ", "النازعات", "عبس",
            "التكوير", "الانفطار", "المطففين", "الانشقاق", "البروج", "الطارق", "الأعلى", "الغاشية", "الفجر", "البلد",
            "الشمس", "الليل", "الضحى", "الشرح", "التين", "العلق", "القدر", "البينة", "الزلزلة", "العاديات",
            "القارعة", "التكاثر", "العصر", "الهمزة", "الفيل", "قريش", "الماعون", "الكوثر", "الكافرون", "النصر",
            "المسد", "الإخلاص", "الفلق", "الناس"
        ];

        const surahsData = surahNames.map((name, index) => ({ id: index + 1, name: name }));

        let state = {
            currentTab: 'reciters',
            reciter: recitersData[0],
            surahId: 1,
            isPlaying: false,
            favorites: JSON.parse(localStorage.getItem('quran_favs')) || [],
            theme: localStorage.getItem('theme') || 'light'
        };

        const audio = document.getElementById('audioPlayer');
        const playBtn = document.getElementById('playBtn');
        const searchInput = document.getElementById('searchInput');
        const recitersGrid = document.getElementById('recitersGrid');
        const surahsList = document.getElementById('surahsList');
        const tabBtns = document.querySelectorAll('.tab-btn');
        const elSurahName = document.getElementById('currentSurahName');
        const elReciterName = document.getElementById('currentReciterName');

        function init() {
            setTheme(state.theme);
            renderReciters(recitersData);
            renderSurahs(surahsData);
            setupEventListeners();
        }

        // --- Core Audio Logic with Backup ---
        function loadTrack(reciter, surahId, autoPlay = true, useBackup = false) {
            state.reciter = reciter;
            state.surahId = surahId;

            const paddedId = String(surahId).padStart(3, '0');
            // Try Backup if flag is true, otherwise Main
            const server = (useBackup && reciter.backup) ? reciter.backup : reciter.server;
            
            // Note: QuranicAudio sometimes uses different filenaming, but mostly 001.mp3
            // We assume standard format.
            audio.src = `${server}${paddedId}.mp3`;
            
            // Error Handling for Backup
            audio.onerror = () => {
                if (!useBackup && reciter.backup) {
                    console.log("Main link failed, trying backup...");
                    loadTrack(reciter, surahId, autoPlay, true);
                } else {
                    console.log("All links failed");
                    // Optionally alert user or show error UI
                }
            };

            const surahName = surahsData.find(s => s.id === surahId).name;
            elSurahName.textContent = `سورة ${surahName}`;
            elReciterName.textContent = reciter.name;
            
            highlightActive();

            if (autoPlay) playAudio();
        }

        function playAudio() {
            audio.play().then(() => {
                state.isPlaying = true;
                updatePlayBtn();
            }).catch(e => console.log("Audio load error", e));
        }

        function togglePlay() {
            if(state.isPlaying) {
                audio.pause();
                state.isPlaying = false;
            } else {
                playAudio();
            }
            updatePlayBtn();
        }

        function updatePlayBtn() {
            playBtn.innerHTML = state.isPlaying ? '<i class="fas fa-pause"></i>' : '<i class="fas fa-play" style="margin-right: -4px;"></i>';
        }

        // --- Rendering ---
        function renderReciters(list, isFavView = false) {
            recitersGrid.innerHTML = '';
            if(list.length === 0) {
                recitersGrid.innerHTML = '<p style="text-align:center; width:100%; color:var(--text-secondary)">لا توجد نتائج</p>';
                return;
            }
            
            list.forEach(r => {
                const isFav = state.favorites.includes(r.id);
                const card = document.createElement('div');
                card.className = `card ${r.id === state.reciter.id ? 'active' : ''}`;
                // Clicking card plays (unless clicking heart)
                card.onclick = (e) => {
                    if(!e.target.closest('.fav-btn')) {
                        loadTrack(r, state.surahId, true);
                        if(window.innerWidth < 768) window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                };

                card.innerHTML = `
                    <div class="card-icon"><i class="fas fa-microphone-alt"></i></div>
                    <div class="card-info">
                        <h3 class="card-title">${r.name}</h3>
                        <p class="card-meta">${r.style}</p>
                    </div>
                    <button class="fav-btn ${isFav ? 'is-fav' : ''}" onclick="toggleFav(${r.id}, this)">
                        <i class="${isFav ? 'fas' : 'far'} fa-heart"></i>
                    </button>
                `;
                recitersGrid.appendChild(card);
            });
        }

        function renderSurahs(list) {
            surahsList.innerHTML = '';
            list.forEach(s => {
                const item = document.createElement('div');
                item.className = `surah-item ${s.id === state.surahId ? 'active' : ''}`;
                item.onclick = () => {
                    loadTrack(state.reciter, s.id, true);
                    if(window.innerWidth < 768) window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                item.innerHTML = `
                    <div class="surah-info">
                        <div class="surah-number">${s.id}</div>
                        <span class="surah-name">سورة ${s.name}</span>
                    </div>
                    <i class="far fa-play-circle" style="color: var(--text-secondary);"></i>
                `;
                surahsList.appendChild(item);
            });
        }

        function highlightActive() {
            if(state.currentTab === 'reciters') renderReciters(recitersData); // Refresh to show active
            if(state.currentTab === 'surahs') renderSurahs(surahsData);
            if(state.currentTab === 'favorites') showFavorites();
        }

        // --- Tabs & Favorites ---
        window.toggleFav = function(id, btn) {
            const index = state.favorites.indexOf(id);
            if (index === -1) {
                state.favorites.push(id);
                btn.classList.add('is-fav');
                btn.querySelector('i').className = 'fas fa-heart';
            } else {
                state.favorites.splice(index, 1);
                btn.classList.remove('is-fav');
                btn.querySelector('i').className = 'far fa-heart';
                if(state.currentTab === 'favorites') showFavorites();
            }
            localStorage.setItem('quran_favs', JSON.stringify(state.favorites));
        }

        function showFavorites() {
            const favReciters = recitersData.filter(r => state.favorites.includes(r.id));
            renderReciters(favReciters, true);
        }

        function setupEventListeners() {
            playBtn.addEventListener('click', togglePlay);
            document.getElementById('themeBtn').addEventListener('click', () => {
                const newTheme = state.theme === 'light' ? 'dark' : 'light';
                setTheme(newTheme);
            });

            // Tabs
            tabBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    tabBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    state.currentTab = btn.dataset.tab;
                    searchInput.value = ''; // Reset search

                    document.getElementById('recitersSection').style.display = 'none';
                    document.getElementById('surahsSection').style.display = 'none';

                    if(state.currentTab === 'reciters') {
                        document.getElementById('recitersSection').style.display = 'block';
                        renderReciters(recitersData);
                        searchInput.placeholder = "بحث عن قارئ...";
                    } else if(state.currentTab === 'surahs') {
                        document.getElementById('surahsSection').style.display = 'block';
                        renderSurahs(surahsData);
                        searchInput.placeholder = "بحث عن سورة...";
                    } else if(state.currentTab === 'favorites') {
                        document.getElementById('recitersSection').style.display = 'block';
                        showFavorites();
                        searchInput.placeholder = "بحث في المفضلة...";
                    }
                });
            });

            // Search
            searchInput.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase();
                if(state.currentTab === 'reciters') {
                    renderReciters(recitersData.filter(r => r.name.includes(term)));
                } else if(state.currentTab === 'surahs') {
                    renderSurahs(surahsData.filter(s => s.name.includes(term)));
                } else if(state.currentTab === 'favorites') {
                    const favs = recitersData.filter(r => state.favorites.includes(r.id));
                    renderReciters(favs.filter(r => r.name.includes(term)), true);
                }
            });

            // Audio Progress
            audio.addEventListener('timeupdate', () => {
                if(isNaN(audio.duration)) return;
                const pct = (audio.currentTime / audio.duration) * 100;
                document.getElementById('progressBar').style.width = `${pct}%`;
                document.getElementById('currentTime').textContent = formatTime(audio.currentTime);
                document.getElementById('duration').textContent = formatTime(audio.duration);
            });
            
            document.getElementById('progressContainer').addEventListener('click', function(e) {
                const width = this.clientWidth;
                const clickX = e.offsetX;
                const duration = audio.duration;
                audio.currentTime = (clickX / width) * duration;
            });

            // Next/Prev
            document.getElementById('nextBtn').addEventListener('click', () => {
                if(state.surahId > 1) loadTrack(state.reciter, state.surahId - 1, true);
            });
            document.getElementById('prevBtn').addEventListener('click', () => {
                if(state.surahId < 114) loadTrack(state.reciter, state.surahId + 1, true);
            });
            audio.addEventListener('ended', () => {
                if(state.surahId < 114) loadTrack(state.reciter, state.surahId + 1, true);
            });
        }

        function setTheme(t) {
            document.documentElement.setAttribute('data-theme', t);
            state.theme = t;
            localStorage.setItem('theme', t);
            document.getElementById('themeBtn').innerHTML = t === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        }

        function formatTime(s) {
            const m = Math.floor(s / 60);
            const sec = Math.floor(s % 60);
            return `${m}:${sec < 10 ? '0' : ''}${sec}`;
        }

        init();
    </script>
</body>
</html>

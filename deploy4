    <div class="container">
        <header>
            <a href="#" class="logo"><i class="fas fa-quran"></i><span>القرآن الكريم</span></a>
            <button class="theme-toggle" id="themeBtn"><i class="fas fa-moon"></i></button>
        </header>

        <section class="player-hero">
            <div class="audio-player-wrapper">
                <div class="player-layout">
                    <div class="track-info-side">
                        <h2 class="surah-name-display" id="currentSurahName">قرآن يتلى</h2>
                        <p class="reciter-name-display" id="currentReciterName">آناء الليل وأطراف النهار</p>
                    </div>

                    <div class="controls-side">
                        <div class="range-wrapper">
                            <input type="range" id="progressBar" min="0" max="100" step="0.1" value="0">
                        </div>
                        
                        <div class="time-stamps">
                            <span id="currentTime">00:00</span>
                            <span id="duration">00:00</span>
                        </div>

                        <div class="controls-row">
                            <button class="btn-icon random-btn" id="randomBtn" title="سورة عشوائية بصوت عشوائي">
                                <i class="fas fa-shuffle"></i>
                            </button>

                            <button class="btn-icon" id="nextBtn">
                                <i class="fas fa-step-forward"></i>
                            </button>

                            <button class="btn-play-main" id="playBtn">
                                <i class="fas fa-play" style="margin-right: -4px;"></i>
                            </button>

                            <button class="btn-icon" id="prevBtn">
                                <i class="fas fa-step-backward"></i>
                            </button>

                            <button class="btn-icon" id="modeBtn" title="نمط التشغيل">
                                <i class="fas fa-list-ol"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="search-wrapper">
            <input type="search" id="searchInput" class="search-box" placeholder="بحث عن قارئ...">
        </div>

        <div class="tabs">
            <button class="tab-btn active" data-tab="reciters">القراء</button>
            <button class="tab-btn" data-tab="surahs">السور</button>
            <button class="tab-btn" data-tab="favorites">المفضلة</button>
        </div>

        <section id="recitersSection">
            <div class="grid-layout" id="recitersGrid"></div>
            <div class="pagination" id="pagination">
                <button class="page-btn" id="prevPage" disabled>السابق</button>
                <span class="page-info" id="pageInfo">صفحة 1 من 1</span>
                <button class="page-btn" id="nextPage">التالي</button>
            </div>
        </section>

        <section id="surahsSection" style="display: none;"><div class="surah-list" id="surahsList"></div></section>
        
        <footer class="app-footer">
            <p>صدقة جارية</p>
            <p>تم التطوير بواسطة <span class="dev-name">عبدالرحمن خالد</span></p>
            <div class="footer-links">
                <a href="https://www.linkedin.com/in/abdulrahman-khalid-arks" target="_blank" rel="noopener noreferrer"><i class="fab fa-linkedin"></i></a>
                <a href="https://github.com/abdulrahman-khalid-elhady" target="_blank" rel="noopener noreferrer"><i class="fab fa-github"></i></a>
            </div>
        </footer>
    </div>


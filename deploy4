    "id": 236,
    "name": "عبدالرحمن بن عبدالرزاق البدر",
    "style": "حفص عن عاصم",
    "server": "https://server16.mp3quran.net/A-AlBadr/Rewayat-Hafs-A-n-Assem/"
  }];
        const surahNames = [
            "الفاتحة", "البقرة", "آل عمران", "النساء", "المائدة", "الأنعام", "الأعراف", "الأنفال", "التوبة", "يونس",
            "هود", "يوسف", "الرعد", "إبراهيم", "الحجر", "النحل", "الإسراء", "الكهف", "مريم", "طه",
            "الأنبياء", "الحج", "المؤمنون", "النور", "الفرقان", "الشعراء", "النمل", "القصص", "العنكبوت", "الروم",
            "لقمان", "السجدة", "الأحزاب", "سبأ", "فاطر", "يس", "الصافات", "ص", "الزمر", "غافر",
            "فصلت", "الشورى", "الزخرف", "الدخان", "الجاثية", "الأحقاف", "محمد", "الفتح", "الحجرات", "ق",
            "الذاريات", "الطور", "النجم", "القمر", "الرحمن", "الواقعة", "الحديد", "المجادلة", "الحشر", "الممتحنة",
            "الصف", "الجمعة", "المنافقون", "التغابن", "الطلاق", "التحريم", "الملك", "القلم", "الحاقة", "المعارج",
            "نوح", "الجن", "المزمل", "المدثر", "القيامة", "الإنسان", "المرسلات", "النبأ", "النازعات", "عبس",
            "التكوير", "الانفطار", "المطففين", "الانشقاق", "البروج", "الطارق", "الأعلى", "الغاشية", "الفجر", "البلد",
            "الشمس", "الليل", "الضحى", "الشرح", "التين", "العلق", "القدر", "البينة", "الزلزلة", "العاديات",
            "القارعة", "التكاثر", "العصر", "الهمزة", "الفيل", "قريش", "الماعون", "الكوثر", "الكافرون", "النصر",
            "المسد", "الإخلاص", "الفلق", "الناس"
        ];
        const surahsData = surahNames.map((name, index) => ({ id: index + 1, name: name }));

        let state = {
            currentTab: 'reciters', reciter: recitersData[0] || {id: 109, name: "مشاري العفاسي", server: "https://server8.mp3quran.net/afs/"},
            surahId: 1, isPlaying: false, favorites: JSON.parse(localStorage.getItem('quran_favs')) || [],
            theme: localStorage.getItem('theme') || 'light', currentPage: 1, itemsPerPage: 20,
            playbackMode: 'list' // 'list' | 'repeat'
        };

        const audio = document.getElementById('audioPlayer');
        const playBtn = document.getElementById('playBtn');
        const progressBar = document.getElementById('progressBar'); // New input range
        const searchInput = document.getElementById('searchInput');
        const recitersGrid = document.getElementById('recitersGrid');
        const surahsList = document.getElementById('surahsList');
        const modeBtn = document.getElementById('modeBtn');
        const randomBtn = document.getElementById('randomBtn');

        function init() {
            setTheme(state.theme);
            renderView();
            setupEventListeners();
        }

        function renderView() {
            const term = searchInput.value.toLowerCase();
            let list = [];

            if (state.currentTab === 'reciters') {
                list = recitersData.filter(r => r.name.includes(term));
                document.getElementById('pagination').style.display = 'flex';
                renderPaginatedReciters(list);
            } else if (state.currentTab === 'surahs') {
                list = surahsData.filter(s => s.name.includes(term));
                document.getElementById('pagination').style.display = 'none';
                renderSurahs(list);
            } else if (state.currentTab === 'favorites') {
                list = recitersData.filter(r => state.favorites.includes(r.id) && r.name.includes(term));
                document.getElementById('pagination').style.display = 'none';
                renderReciters(list);
            }
        }

        function renderPaginatedReciters(list) {
            const totalPages = Math.ceil(list.length / state.itemsPerPage);
            state.currentPage = Math.min(state.currentPage, totalPages || 1);
            const start = (state.currentPage - 1) * state.itemsPerPage;
            const paginatedList = list.slice(start, start + state.itemsPerPage);
            
            renderReciters(paginatedList);
            document.getElementById('pageInfo').textContent = `صفحة ${state.currentPage} من ${totalPages || 1}`;
            document.getElementById('prevPage').disabled = state.currentPage === 1;
            document.getElementById('nextPage').disabled = state.currentPage === totalPages || totalPages === 0;
        }

        function renderReciters(list) {
            recitersGrid.innerHTML = list.length ? '' : '<p style="text-align:center; width:100%; color:var(--text-secondary)">لا توجد نتائج</p>';
            list.forEach(r => {
                const card = document.createElement('div');
                card.className = `card ${r.id === state.reciter.id ? 'active' : ''}`;
                card.onclick = (e) => { if(!e.target.closest('.fav-btn')) loadTrack(r, state.surahId); };
                card.innerHTML = `<div class="card-icon"><i class="fas fa-microphone-alt"></i></div><div class="card-info"><h3 class="card-title">${r.name}</h3><p class="card-meta">${r.style}</p></div><button class="fav-btn ${state.favorites.includes(r.id) ? 'is-fav' : ''}" onclick="toggleFav(${r.id}, this)"><i class="${state.favorites.includes(r.id) ? 'fas' : 'far'} fa-heart"></i></button>`;
                recitersGrid.appendChild(card);
            });
        }

        function renderSurahs(list) {
            surahsList.innerHTML = '';
            list.forEach(s => {
                const item = document.createElement('div');
                item.className = `surah-item ${s.id === state.surahId ? 'active' : ''}`;
                item.onclick = () => loadTrack(state.reciter, s.id);
                item.innerHTML = `<div class="surah-info"><div class="surah-number">${s.id}</div><span class="surah-name">سورة ${s.name}</span></div><i class="far fa-play-circle"></i>`;
                surahsList.appendChild(item);
            });
        }

        function loadTrack(reciter, surahId) {
            state.reciter = reciter; state.surahId = surahId;
            const paddedId = String(surahId).padStart(3, '0');
            audio.src = `${reciter.server}${paddedId}.mp3`;
            audio.onerror = () => {
                const toast = document.createElement('div');
                toast.className = 'error-toast';
                toast.innerText = 'عذراً، هذه السورة غير متوفرة حالياً من المصدر';
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 4000); 
            };
            document.getElementById('currentSurahName').textContent = `سورة ${surahsData.find(s => s.id === surahId).name}`;
            document.getElementById('currentReciterName').textContent = reciter.name;
            highlightActive();
            playAudio();
            // Optional: only scroll if on mobile to avoid jumping on desktop
            if(window.innerWidth < 768) window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function playAudio() { audio.play().then(() => { state.isPlaying = true; updatePlayBtn(); }).catch(() => {}); }
        function togglePlay() { if(state.isPlaying) audio.pause(); else playAudio(); state.isPlaying = !state.isPlaying; updatePlayBtn(); }
        function updatePlayBtn() { 
            // Update icon only, class handled in CSS
            playBtn.innerHTML = state.isPlaying ? '<i class="fas fa-pause"></i>' : '<i class="fas fa-play" style="margin-right: -4px;"></i>'; 
        }
        
        function highlightActive() {
            document.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.surah-item').forEach(s => s.classList.remove('active'));
            renderView(); // Re-render to update active class in grid
        }

        window.toggleFav = function(id, btn) {
            const idx = state.favorites.indexOf(id);
            if (idx === -1) state.favorites.push(id); else state.favorites.splice(idx, 1);
            localStorage.setItem('quran_favs', JSON.stringify(state.favorites));
            renderView();
        };

        // --- NEW FUNCTIONS FOR PLAYER LOGIC ---

        function toggleMode() {
            if (state.playbackMode === 'list') {
                state.playbackMode = 'repeat';
                modeBtn.innerHTML = '<i class="fas fa-redo"></i>';
                modeBtn.classList.add('active-mode');
                modeBtn.title = 'إعادة السورة الحالية';
            } else {
                state.playbackMode = 'list';
                modeBtn.innerHTML = '<i class="fas fa-list-ol"></i>';
                modeBtn.classList.remove('active-mode');
                modeBtn.title = 'تشغيل تتابعي';
            }
        }

        function playRandom() {
            const randomReciter = recitersData[Math.floor(Math.random() * recitersData.length)];
            const randomSurahId = Math.floor(Math.random() * 114) + 1;
            loadTrack(randomReciter, randomSurahId);
        }

        function onTrackEnded() {
            if (state.playbackMode === 'repeat') {
                audio.currentTime = 0;
                playAudio();
            } else {
                // Next Track
                if (state.surahId < 114) loadTrack(state.reciter, state.surahId + 1);
            }
        }

        function setupEventListeners() {
            playBtn.onclick = togglePlay;
            modeBtn.onclick = toggleMode;
            randomBtn.onclick = playRandom;

            document.getElementById('themeBtn').onclick = () => setTheme(state.theme === 'light' ? 'dark' : 'light');
            document.getElementById('nextBtn').onclick = () => { if(state.surahId > 1) loadTrack(state.reciter, state.surahId - 1); };
            document.getElementById('prevBtn').onclick = () => { if(state.surahId < 114) loadTrack(state.reciter, state.surahId + 1); };
            
            document.getElementById('nextPage').onclick = () => { state.currentPage++; renderView(); };
            document.getElementById('prevPage').onclick = () => { state.currentPage--; renderView(); };
            
            searchInput.oninput = () => { state.currentPage = 1; renderView(); };
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.onclick = () => {
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    state.currentTab = btn.dataset.tab;
                    state.currentPage = 1;
                    
                    const sInput = document.getElementById('searchInput');
                    if (state.currentTab === 'reciters') sInput.placeholder = "بحث عن قارئ...";
                    else if (state.currentTab === 'surahs') sInput.placeholder = "بحث عن سورة...";
                    else if (state.currentTab === 'favorites') sInput.placeholder = "بحث في المفضلة...";
                    
                    document.getElementById('recitersSection').style.display = state.currentTab === 'surahs' ? 'none' : 'block';
                    document.getElementById('surahsSection').style.display = state.currentTab === 'surahs' ? 'block' : 'none';
                    
                    renderView();
                };
            });

            // Audio Events
            audio.onended = onTrackEnded;
            
            audio.ontimeupdate = () => {
                if(isNaN(audio.duration)) return;
                const pct = (audio.currentTime / audio.duration) * 100;
                
                // Update Range Input Value
                progressBar.value = pct;
                
                // Update Gradient Visual (Matches React Logic)
                const isDark = state.theme === 'dark';
                const baseColor = isDark ? '#2A3836' : '#E0DCD5';
                const activeColor = '#D4AF37';
                
                // Note: In RTL context, "to left" fills from Right to Left. 
                // We use standard linear-gradient logic, but applying it to the slider background.
                progressBar.style.background = `linear-gradient(to left, ${activeColor} ${pct}%, ${baseColor} ${pct}%)`;

                document.getElementById('currentTime').textContent = formatTime(audio.currentTime);
                document.getElementById('duration').textContent = formatTime(audio.duration);
            };

            // Seek logic
            progressBar.oninput = (e) => {
                const val = e.target.value;
                audio.currentTime = (val / 100) * audio.duration;
            };
        }

        function setTheme(t) {
            document.documentElement.setAttribute('data-theme', t);
            state.theme = t; localStorage.setItem('theme', t);
            document.getElementById('themeBtn').innerHTML = t === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            
            // Trigger timeupdate to refresh slider color immediately on theme change
            if(audio.duration) audio.ontimeupdate();
        }

        function formatTime(s) {
            const m = Math.floor(s / 60); const sec = Math.floor(s % 60);
            return `${m < 10 ? '0' : ''}${m}:${sec < 10 ? '0' : ''}${sec}`;
        }

        init();
    </script>
</body>
</html>

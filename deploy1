    <style>
        /* --- CSS VARIABLES & THEME SYSTEM --- */
        :root {
            /* Light Theme (Default) */
            --bg-body: #F9F7F2;
            --bg-surface: #FFFFFF;
            --bg-surface-hover: #F2EFE9;
            --text-primary: #1A3C34;
            --text-secondary: #5C706A;
            --primary: #1F4E43;
            --primary-light: #2A6658;
            --accent: #D4AF37;
            --accent-glow: rgba(212, 175, 55, 0.2);
            --border: #E0DCD5;
            --shadow: 0 4px 20px rgba(26, 60, 52, 0.06);
            --shadow-hover: 0 8px 30px rgba(26, 60, 52, 0.12);
            --radius-sm: 8px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-full: 9999px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --font-heading: 'Amiri', serif;
            --font-ui: 'Tajawal', sans-serif;
        }

        [data-theme="dark"] {
            /* Dark Theme */
            --bg-body: #0F1716;
            --bg-surface: #1A2624;
            --bg-surface-hover: #23302E;
            --text-primary: #ECECEC;
            --text-secondary: #A0B3B0;
            --primary: #468C79;
            --primary-light: #5AA390;
            --accent: #C5A028;
            --accent-glow: rgba(197, 160, 40, 0.15);
            --border: #2A3836;
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
            --shadow-hover: 0 8px 30px rgba(0, 0, 0, 0.6);
        }

        /* --- GLOBAL RESET & TYPOGRAPHY --- */
        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
        
        body {
            font-family: var(--font-ui);
            background-color: var(--bg-body);
            color: var(--text-primary);
            line-height: 1.6;
            transition: background-color 0.5s ease, color 0.5s ease;
            overflow-x: hidden;
            background-image: radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 40%);
        }

        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23D4AF37' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
            z-index: -1;
        }

        h1, h2, h3 { font-family: var(--font-heading); font-weight: 700; line-height: 1.4; }
        a { text-decoration: none; color: inherit; transition: var(--transition); }
        button { cursor: pointer; border: none; background: none; font-family: inherit; transition: var(--transition); }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* --- HEADER --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 24px 0;
            position: relative;
            z-index: 10;
        }

        .logo {
            font-family: var(--font-heading);
            font-size: 2rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        [data-theme="dark"] .logo { color: var(--text-primary); }
        .logo i { color: var(--accent); font-size: 1.8rem; }

        .theme-toggle {
            width: 44px;
            height: 44px;
            border-radius: var(--radius-full);
            background: var(--bg-surface);
            border: 1px solid var(--border);
            color: var(--text-primary);
            display: grid;
            place-items: center;
            font-size: 1.2rem;
        }
        .theme-toggle:hover { background: var(--bg-surface-hover); border-color: var(--accent); color: var(--accent); }

        /* --- HERO & PLAYER --- */
        .player-hero {
            text-align: center;
            padding: 40px 0 60px;
            position: relative;
        }

        .surah-name-display {
            font-size: 3.5rem;
            color: var(--primary);
            margin-bottom: 8px;
            text-shadow: 0 4px 12px rgba(0,0,0,0.05);
        }
        
        [data-theme="dark"] .surah-name-display { color: var(--text-primary); }

        .reciter-name-display {
            font-size: 1.2rem;
            color: var(--accent);
            letter-spacing: 0.5px;
            opacity: 0.9;
        }

        .audio-player-wrapper {
            background: var(--bg-surface);
            padding: 24px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            max-width: 700px;
            margin: 30px auto 0;
            position: sticky;
            top: 20px;
            z-index: 100;
            backdrop-filter: blur(10px);
        }
        
        [data-theme="dark"] .audio-player-wrapper { background: rgba(26, 38, 36, 0.9); }

        .progress-container {
            width: 100%;
            height: 6px;
            background: var(--border);
            border-radius: var(--radius-full);
            cursor: pointer;
            position: relative;
            margin-bottom: 20px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: var(--accent);
            width: 0%;
            border-radius: var(--radius-full);
            transition: width 0.1s linear;
        }
        
        .time-stamps {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-top: 8px;
            font-variant-numeric: tabular-nums;
        }

        .controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 24px;
        }

        .btn-control { color: var(--text-secondary); font-size: 1.2rem; padding: 10px; }
        .btn-control:hover { color: var(--primary); }

        .btn-play {
            width: 64px;
            height: 64px;
            background: var(--primary);
            color: #fff;
            border-radius: var(--radius-full);
            font-size: 1.5rem;
            display: grid;
            place-items: center;
            box-shadow: 0 8px 20px rgba(31, 78, 67, 0.3);
        }

        .btn-play:hover { transform: scale(1.05); background: var(--primary-light); }

        /* --- CONTENT SECTIONS --- */
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 24px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 16px;
        }

        .section-title { font-size: 1.8rem; color: var(--text-primary); }
        .section-subtitle { font-size: 0.9rem; color: var(--text-secondary); margin-top: 4px; }

        .tabs {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
            justify-content: center;
        }
        
        .tab-btn {
            padding: 10px 24px;
            border-radius: var(--radius-full);
            font-weight: 500;
            color: var(--text-secondary);
            background: transparent;
            border: 1px solid transparent;
        }
        
        .tab-btn.active {
            background: var(--bg-surface);
            color: var(--primary);
            border-color: var(--border);
            box-shadow: var(--shadow);
        }

        /* Grid & List */
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 20px;
            margin-bottom: 60px;
        }

        .card {
            background: var(--bg-surface);
            border-radius: var(--radius-md);
            padding: 20px;
            border: 1px solid var(--border);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .card:hover { transform: translateY(-5px); box-shadow: var(--shadow-hover); border-color: var(--accent); }
        .card.active { border-color: var(--primary); background: var(--bg-surface-hover); }

        .card-icon {
            width: 44px;
            height: 44px;
            background: var(--bg-body);
            border-radius: var(--radius-full);
            display: grid;
            place-items: center;
            color: var(--primary);
            flex-shrink: 0;
            font-size: 1.1rem;
        }

        .card-info { flex: 1; }
        .card-title { font-size: 1.1rem; margin-bottom: 4px; color: var(--text-primary); }
        .card-meta { font-size: 0.85rem; color: var(--text-secondary); }

        /* Surah List */
        .surah-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
            padding-bottom: 80px;
        }

        .surah-item {
            background: var(--bg-surface);
            padding: 14px 18px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: var(--transition);
        }

        .surah-item:hover { background: var(--bg-surface-hover); border-color: var(--accent); }
        .surah-item.active { background: var(--primary); color: #fff; border-color: var(--primary); }
        .surah-item.active .surah-number { color: rgba(255,255,255,0.6); }

        .surah-info { display: flex; align-items: center; gap: 12px; }
        
        .surah-number {
            font-family: var(--font-ui);
            font-weight: 700;
            font-size: 0.85rem;
            color: var(--accent);
            width: 28px;
            height: 28px;
            display: grid;
            place-items: center;
            background: rgba(0,0,0,0.03);
            border-radius: 6px;
        }

        .surah-name { font-family: var(--font-heading); font-size: 1.15rem; }

        /* Responsive */
        @media (max-width: 768px) {
            .player-hero { padding: 20px 0 40px; }
            .surah-name-display { font-size: 2.2rem; }
            .audio-player-wrapper { 
                padding: 16px; bottom: 0; top: auto; 
                border-radius: 20px 20px 0 0; margin: 0 -20px; 
                max-width: none; width: calc(100% + 40px); 
                border-bottom: none; position: fixed;
            }
            .grid-layout { grid-template-columns: 1fr; gap: 12px; }
            .surah-list { grid-template-columns: 1fr; }
            .container { padding-bottom: 180px; } /* Space for fixed player */
            .tabs { overflow-x: auto; padding: 0 20px 10px; justify-content: flex-start; margin: 0 -20px 20px; }
            .tab-btn { white-space: nowrap; flex-shrink: 0; }
        }

            { id: 302, name: "ياسين الجزائري", style: "ورش عن نافع", server: "https://server11.mp3quran.net/jaza/" },
            { id: 303, name: "عمر القزابري", style: "ورش عن نافع", server: "https://server9.mp3quran.net/omar_warsh/" },
            { id: 304, name: "محمود خليل الحصري", style: "ورش عن نافع", server: "https://server13.mp3quran.net/husr_warsh/" },
            { id: 305, name: "أحمد الحواشي", style: "مرتل (حفص)", server: "https://server11.mp3quran.net/hawashi/" },
            { id: 306, name: "العيون الكوشي", style: "ورش عن نافع", server: "https://server11.mp3quran.net/kushi/" },
            { id: 307, name: "علي بن عبدالرحمن الحذيفي", style: "قالون عن نافع", server: "https://server9.mp3quran.net/hthfi_qalon/" },
            { id: 308, name: "عبدالرشيد صوفي", style: "خلف عن حمزة", server: "https://server10.mp3quran.net/soufi_khalaf/" },
            { id: 309, name: "عبدالرشيد صوفي", style: "السوسي عن أبي عمرو", server: "https://server10.mp3quran.net/soufi_sosi/" }
        ];
        // --- APP LOGIC ---
        let state = {
            isPlaying: false,
            currentReciter: recitersData[0], // Mishary Default
            currentSurahId: 1, // Al-Fatiha
            theme: localStorage.getItem('theme') || 'light'
        };

        const audio = document.getElementById('audioPlayer');
        const playBtn = document.getElementById('playBtn');
        const progressBar = document.getElementById('progressBar');
        const progressContainer = document.getElementById('progressContainer');
        const themeBtn = document.getElementById('themeBtn');
        const recitersGrid = document.getElementById('recitersGrid');
        const surahsList = document.getElementById('surahsList');
        const elSurahName = document.getElementById('currentSurahName');
        const elReciterName = document.getElementById('currentReciterName');
        const elCurrentTime = document.getElementById('currentTime');
        const elDuration = document.getElementById('duration');
        const tabBtns = document.querySelectorAll('.tab-btn');

        function init() {
            setTheme(state.theme);
            renderReciters();
            renderSurahs();
            // Preload UI text but don't auto-play on load
            updateTrackInfo(state.currentReciter, state.currentSurahId);
            setupEventListeners();
        }

        function loadTrack(reciter, surahId, autoPlay = true) {
            state.currentReciter = reciter;
            state.currentSurahId = surahId;

            // Format ID (001, 010, 100)
            const paddedId = String(surahId).padStart(3, '0');
            const url = `${reciter.server}${paddedId}.mp3`;
            
            audio.src = url;
            updateTrackInfo(reciter, surahId);
            highlightActiveItems();

            if (autoPlay) {
                playAudio();
            }
        }

        function updateTrackInfo(reciter, surahId) {
            const surahName = surahsData.find(s => s.id === surahId).name;
            elSurahName.textContent = `سورة ${surahName}`;
            elReciterName.textContent = reciter.name;
        }

        function playAudio() {
            audio.play().then(() => {
                state.isPlaying = true;
                updatePlayBtn();
            }).catch(e => console.log("Error playing:", e));
        }

        function pauseAudio() {
            audio.pause();
            state.isPlaying = false;
            updatePlayBtn();
        }

        function togglePlay() {
            state.isPlaying ? pauseAudio() : playAudio();
        }

        function updatePlayBtn() {
            const icon = playBtn.querySelector('i');
            if (state.isPlaying) {
                icon.className = 'fas fa-pause';
            } else {
                icon.className = 'fas fa-play';
                icon.style.marginRight = '-4px';
            }
        }

        function renderReciters() {
            recitersGrid.innerHTML = '';
            recitersData.forEach(reciter => {
                const card = document.createElement('div');
                card.className = 'card';
                card.dataset.id = reciter.id;
                card.onclick = () => {
                    loadTrack(reciter, state.currentSurahId, true);
                    // Stay on reciter tab but show visual feedback
                };

                card.innerHTML = `
                    <div class="card-icon"><i class="fas fa-microphone-alt"></i></div>
                    <div class="card-info">
                        <h3 class="card-title">${reciter.name}</h3>
                        <p class="card-meta">${reciter.style}</p>
                    </div>
                `;
                recitersGrid.appendChild(card);
            });
            highlightActiveItems();
        }

        function renderSurahs() {
            surahsList.innerHTML = '';
            surahsData.forEach(surah => {
                const item = document.createElement('div');
                item.className = 'surah-item';
                item.dataset.id = surah.id;
                item.onclick = () => loadTrack(state.currentReciter, surah.id, true);
                
                item.innerHTML = `
                    <div class="surah-info">
                        <div class="surah-number">${surah.id}</div>
                        <span class="surah-name">سورة ${surah.name}</span>
                    </div>
                    <i class="far fa-play-circle" style="color: var(--text-secondary);"></i>
                `;
                surahsList.appendChild(item);
            });
        }

        function highlightActiveItems() {
            document.querySelectorAll('.card').forEach(c => {
                c.classList.toggle('active', parseInt(c.dataset.id) === state.currentReciter.id);
            });
            document.querySelectorAll('.surah-item').forEach(s => {
                s.classList.toggle('active', parseInt(s.dataset.id) === state.currentSurahId);
            });
        }

        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            state.theme = theme;
            localStorage.setItem('theme', theme);
            themeBtn.innerHTML = theme === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        }

        function switchTab(target) {
            if(target === 'reciters') {
                document.getElementById('recitersSection').style.display = 'block';
                document.getElementById('surahsSection').style.display = 'none';
            } else if (target === 'surahs') {
                document.getElementById('recitersSection').style.display = 'none';
                document.getElementById('surahsSection').style.display = 'block';
            }
            
            tabBtns.forEach(btn => {
                btn.classList.toggle('active', btn.dataset.tab === target);
            });
        }

        function setupEventListeners() {
            playBtn.addEventListener('click', togglePlay);
            themeBtn.addEventListener('click', () => setTheme(state.theme === 'light' ? 'dark' : 'light'));
            
            audio.addEventListener('timeupdate', updateProgress);
            audio.addEventListener('ended', () => {
                if(state.currentSurahId < 114) loadTrack(state.currentReciter, state.currentSurahId + 1, true);
            });

            progressContainer.addEventListener('click', (e) => {
                const width = progressContainer.clientWidth;
                // In RTL, the click calc can sometimes be tricky depending on browser, 
                // but usually offsetX gives the distance from the visual left edge of element in modern browsers.
                // If the bar fills from right to left, we might need to invert logic.
                // However, our CSS width grows normally. Let's assume standard behavior.
                const clickX = e.offsetX;
                const duration = audio.duration;
                audio.currentTime = (clickX / width) * duration;
            });

            tabBtns.forEach(btn => btn.addEventListener('click', () => switchTab(btn.dataset.tab)));

            document.getElementById('nextBtn').addEventListener('click', () => {
                 if(state.currentSurahId > 1) loadTrack(state.currentReciter, state.currentSurahId - 1, true);
            });
            document.getElementById('prevBtn').addEventListener('click', () => {
                 if(state.currentSurahId < 114) loadTrack(state.currentReciter, state.currentSurahId + 1, true);
            });
        }

        function updateProgress() {
            const { duration, currentTime } = audio;
            if(isNaN(duration)) return;
            const progressPercent = (currentTime / duration) * 100;
            progressBar.style.width = `${progressPercent}%`;
            elCurrentTime.textContent = formatTime(currentTime);
            elDuration.textContent = formatTime(duration);
        }

        function formatTime(seconds) {
            const min = Math.floor(seconds / 60);
            const sec = Math.floor(seconds % 60);
            return `${min}:${sec < 10 ? '0' : ''}${sec}`;
        }

        init();
    </script>
